# ── PostgreSQL ──────────────────────────────
POSTGRES_DB=stockapp
POSTGRES_USER=stockapp
POSTGRES_PASSWORD=changeme          # ← change this!

# ── App ─────────────────────────────────────
APP_PORT=8501                       # host port for the Streamlit UI

# ── Telegram ────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Auto-deploy webhook (optional) ──────────────────────────────────────────
# Generate a random secret: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=
WEBHOOK_PORT=9000
